# Nockchain Jammer Configuration
# Copy to .env and customize before running install.sh

# Nockchain node settings
NOCKCHAIN_BIN=/home/nockchain/.cargo/bin/nockchain
NOCKCHAIN_DIR=/home/nockchain/nockchain
# Live export via nockchain private gRPC (NockApp::export_state). Node keeps running.
NOCKCHAIN_USER=nockchain
NOCKCHAIN_SERVICE=nockchain
NOCKCHAIN_RPC=localhost:5556
NOCKCHAIN_PRIVATE_GRPC=http://127.0.0.1:5555

# API settings
API_KEY=
API_PORT=3001

# File paths
HTML_ROOT=/usr/share/nginx/html
JAMS_DIR=/usr/share/nginx/html/jams
MANIFEST=/usr/share/nginx/html/jams/SHA256SUMS
